{
  "expo": {
    "name": "MemQ: Smart Quiz & Memory",
    "slug": "memq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "memq",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.river.memq",
      "usesAppleSignIn": true,
      "buildNumber": "1",
      "requireFullScreen": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIRequiresFullScreen": true,
        "LSRequiresIPhoneOS": true,
        "NSPhotoLibraryUsageDescription": "MemQ uses your photo library to let you select and upload a profile picture for your account, and to import images from your photos to create study materials. For example, you can choose a photo from your library to set as your profile avatar, or select an image containing text that you want to convert into study flashcards."
      },
      "appleTeamId": "28G88H73PM"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.river.memq",
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d79756a6-1f34-4dc7-8c8f-f822aab4e372"
      }
    }
  }
}
